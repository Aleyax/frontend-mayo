{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "node dist/frontend/server/server.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:pos": "vitest run --environment jsdom src/app/order/components/pos.component.pos-flow.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:pos": "playwright test e2e/pos-payment.e2e.spec.ts",
    "test:e2e:screenshots": "playwright test e2e/admin-screenshots.e2e.spec.ts",
    "test:e2e:guide:screenshots": "playwright test e2e/user-guide-screenshots.e2e.spec.ts",
    "serve:ssr:frontend": "node dist/frontend/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/platform-browser": "21.2.11",
    "@angular/platform-server": "21.2.11",
    "@angular/router": "21.2.11",
    "@angular/ssr": "^21.2.9",
    "@tailwindcss/postcss": "^4.2.4",
    "daisyui": "^5.5.19",
    "express": "^5.1.0",
    "postcss": "^8.5.14",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.11",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
